# =============================================================================
# LLM Provider
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# Model Configuration
# =============================================================================
# Options: gpt-4o-mini, gpt-4o, gpt-4-turbo
LLM_MODEL=gpt-4o-mini

# Maximum tokens for LLM response
LLM_MAX_TOKENS=4096

# Temperature for generation (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.0

# Maximum retry attempts for malformed LLM responses
LLM_MAX_RETRIES=3

# =============================================================================
# Data Configuration
# =============================================================================
# Number of contracts to process from CUAD dataset
NUM_CONTRACTS=50

# HuggingFace dataset identifier
HF_DATASET=dvgodoy/CUAD_v1_Contract_Understanding_PDF

# =============================================================================
# Processing Configuration
# =============================================================================
# Maximum characters per chunk when splitting long contracts
CHUNK_SIZE=12000

# Overlap between chunks in characters
CHUNK_OVERLAP=500

# =============================================================================
# Embedding Configuration (Bonus)
# =============================================================================
# Sentence-transformer model for embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of similar clauses to retrieve
SEARCH_TOP_K=5

# =============================================================================
# Output Configuration
# =============================================================================
OUTPUT_DIR=outputs
LOG_LEVEL=INFO
